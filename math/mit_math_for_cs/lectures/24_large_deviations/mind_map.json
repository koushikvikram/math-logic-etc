{
  "name": "Large Deviations and Tail Bounds",
  "children": [
    {
      "name": "Variance Review",
      "children": [
        {
          "name": "Definition: E[(R - E[R])^2]"
        },
        {
          "name": "Formula: E[R^2] - (E[R])^2"
        },
        {
          "name": "Standard Deviation: sqrt(Variance)"
        },
        {
          "name": "Linearity: Requires pairwise independence"
        }
      ]
    },
    {
      "name": "Markov's Inequality",
      "children": [
        {
          "name": "Constraint: Non-negative random variable"
        },
        {
          "name": "Formula: P(R >= x) <= E[R] / x"
        },
        {
          "name": "Relative Form: P(R >= C*E[R]) <= 1/C"
        },
        {
          "name": "Proof: Law of total expectation"
        },
        {
          "name": "Optimization Techniques",
          "children": [
            {
              "name": "Shifting: Subtracting lower bound"
            },
            {
              "name": "Flipping: Maximum minus R"
            }
          ]
        },
        {
          "name": "Tightness",
          "children": [
            {
              "name": "Tight: Lazy Susan phone problem"
            },
            {
              "name": "Not Tight: Random permutations"
            }
          ]
        }
      ]
    },
    {
      "name": "Chebyshev's Inequality",
      "children": [
        {
          "name": "Constraint: Requires variance"
        },
        {
          "name": "Formula: P(|R - E[R]| >= x) <= Var(R) / x^2"
        },
        {
          "name": "Proof: Apply Markov to R' = (R - E[R])^2"
        },
        {
          "name": "Strength: Stronger than Markov (quadratic vs linear)"
        }
      ]
    },
    {
      "name": "Chernoff Bound",
      "children": [
        {
          "name": "Constraint: Mutually independent variables"
        },
        {
          "name": "Formula: Exponential decay in n"
        },
        {
          "name": "Proof Sketch: Exponentiate and apply Markov"
        },
        {
          "name": "Strength: Strongest bound (exponential)"
        }
      ]
    },
    {
      "name": "Comparison Example: Coin Flips",
      "children": [
        {
          "name": "Markov: Constant (e.g., 2/3)"
        },
        {
          "name": "Chebyshev: Linear (e.g., 4/n)"
        },
        {
          "name": "Chernoff: Exponential (e^-O(n))"
        }
      ]
    }
  ]
}