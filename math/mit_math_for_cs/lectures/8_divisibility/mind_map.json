{
  "name": "Number Theory: Divisibility and GCD",
  "children": [
    {
      "name": "Divisibility Fundamentals",
      "children": [
        {
          "name": "Definition: a divides b (b = ka)"
        },
        {
          "name": "Notation: a | b"
        },
        {
          "name": "Properties",
          "children": [
            {
              "name": "Common divisor divides sums/differences"
            },
            {
              "name": "Common divisor divides any ILC"
            },
            {
              "name": "Everything divides 0"
            },
            {
              "name": "0 is even (2 divides 0)"
            }
          ]
        }
      ]
    },
    {
      "name": "Integer Linear Combination (ILC)",
      "children": [
        {
          "name": "Form: sa + tb (s, t are integers)"
        },
        {
          "name": "Property: d|a and d|b implies d|ILC(a, b)"
        }
      ]
    },
    {
      "name": "Water-Pouring Puzzle",
      "children": [
        {
          "name": "State Machine Representation",
          "children": [
            {
              "name": "States (x, y): gallons in jugs"
            },
            {
              "name": "Initial state: (0, 0)"
            },
            {
              "name": "Transitions: fill, empty, pour"
            }
          ]
        },
        {
          "name": "Analysis",
          "children": [
            {
              "name": "Invariant: x and y are ILCs of capacities"
            },
            {
              "name": "Impossible if target is not multiple of GCD"
            },
            {
              "name": "Solvable iff target is ILC within capacity"
            }
          ]
        }
      ]
    },
    {
      "name": "Greatest Common Divisor (GCD)",
      "children": [
        {
          "name": "Definitions",
          "children": [
            {
              "name": "Largest common divisor"
            },
            {
              "name": "Non-negative divisor of all common divisors"
            }
          ]
        },
        {
          "name": "Special Cases",
          "children": [
            {
              "name": "GCD(0, 0) = 0"
            },
            {
              "name": "GCD(0, b) = |b|"
            }
          ]
        }
      ]
    },
    {
      "name": "Euclidean Algorithm",
      "children": [
        {
          "name": "Subtraction Lemma",
          "children": [
            {
              "name": "GCD(a, b) = GCD(a-b, b)"
            },
            {
              "name": "Slow: O(a+b) steps"
            }
          ]
        },
        {
          "name": "Division Theorem",
          "children": [
            {
              "name": "n = qd + r (unique q, r)"
            },
            {
              "name": "Remainder (n rem d) where 0 <= r < d"
            }
          ]
        },
        {
          "name": "Division Method (Fast)",
          "children": [
            {
              "name": "GCD(a, b) = GCD(b, a rem b)"
            },
            {
              "name": "Exponential improvement"
            },
            {
              "name": "Logarithmic time (O(log a))"
            }
          ]
        }
      ]
    },
    {
      "name": "Bézout's Lemma and Pulverizer",
      "children": [
        {
          "name": "Bézout's Lemma",
          "children": [
            {
              "name": "GCD(a, b) is an ILC of a and b"
            }
          ]
        },
        {
          "name": "The Pulverizer",
          "children": [
            {
              "name": "Extended Euclidean Algorithm"
            },
            {
              "name": "History: Aryabhata (500 ACE)"
            },
            {
              "name": "Function: Finds coefficients s, t"
            }
          ]
        }
      ]
    }
  ]
}